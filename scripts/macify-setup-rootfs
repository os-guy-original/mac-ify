#!/bin/bash
# macify-setup-rootfs — install macOS binaries into the macify prefix
#
# Creates a Wine-like fake rootfs at ~/.macify/ where macOS binaries
# see their own /bin/, /usr/bin/, etc. — never Linux binaries.
#
# Usage: macify-setup-rootfs

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Find macify binary and source tree
MACIFY_BIN="${MACIFY_BINARY:-}"
if [ -z "$MACIFY_BIN" ] || [ ! -f "$MACIFY_BIN" ]; then
    if [ -f "$SCRIPT_DIR/../macify" ]; then
        MACIFY_BIN="$SCRIPT_DIR/../macify"
    elif [ -f "$SCRIPT_DIR/../build/macify" ]; then
        MACIFY_BIN="$SCRIPT_DIR/../build/macify"
    fi
fi
SHIM_DIR="$(dirname "$MACIFY_BIN")"
export LD_LIBRARY_PATH="$SHIM_DIR"

# Find tests/real/ directory (macOS binaries source)
REAL_DIR=""
for d in "$SCRIPT_DIR/../tests/real" "$SCRIPT_DIR/tests/real"; do
    if [ -d "$d" ]; then
        REAL_DIR="$d"
        break
    fi
done

PREFIX="${MACIFY_PREFIX:-$HOME/.macify}"

echo "Setting up macOS rootfs at $PREFIX"

if [ -z "$MACIFY_BIN" ] || [ ! -f "$MACIFY_BIN" ]; then
    echo "ERROR: cannot find macify binary" >&2
    exit 1
fi

# Initialize prefix if needed
if [ ! -f "$PREFIX/.macify_prefix" ]; then
    "$MACIFY_BIN" "$REAL_DIR/echo_macos" init >/dev/null 2>&1 || true
fi

if [ -z "$REAL_DIR" ] || [ ! -d "$REAL_DIR" ]; then
    echo "WARNING: tests/real/ not found — run scripts/fetch_binaries.sh first" >&2
fi

# ── Install bash + dylib deps via Homebrew ──────────────────────
BASH_SRC="$PREFIX/usr/local/opt/bash/bin/bash"
if [ ! -f "$BASH_SRC" ]; then
    echo "  Installing bash..."
    bash "$SCRIPT_DIR/macify-setup-homebrew" bash 2>/dev/null
fi

echo "  Checking dylib dependencies..."
for pkg in readline ncurses gettext; do
    if [ ! -d "$PREFIX/usr/local/opt/$pkg" ]; then
        echo "    Installing $pkg..."
        bash "$SCRIPT_DIR/macify-setup-homebrew" "$pkg" 2>/dev/null
    fi
done

# ── Create directory structure ──────────────────────────────────
mkdir -p "$PREFIX"/{bin,etc,sbin,tmp,var}
mkdir -p "$PREFIX/usr"/{bin,sbin,lib,local}
mkdir -p "$PREFIX/usr/local"/{bin,lib,opt,Cellar}

# ── Install bash ────────────────────────────────────────────────
if [ -f "$BASH_SRC" ]; then
    cp "$BASH_SRC" "$PREFIX/bin/bash"
    chmod 755 "$PREFIX/bin/bash"
    ln -sf bash "$PREFIX/bin/sh"
fi

# ── Install coreutils from tests/real/ ──────────────────────────
install_binary() {
    local name="$1"
    local dest_dir="$2"
    local src="$REAL_DIR/${name}_macos"
    if [ -f "$src" ]; then
        cp "$src" "$dest_dir/$name"
        chmod 755 "$dest_dir/$name"
    fi
}

echo "  Installing coreutils..."
# /bin/ — essential
for bin in cat echo false true pwd test; do
    install_binary "$bin" "$PREFIX/bin"
done

# /usr/bin/ — standard utilities
for bin in basename cp cut date dd df dir dirname du env expand expr \
           fmt fold head hostid hostname id install join link ln ls \
           mkdir mktemp mv nl nohup nproc numfmt od paste printenv \
           printf ptouch pwd readlink realpath rm rmdir seq sha1sum \
           sha256sum sha512sum shred shuf sleep sort split stat stdbuf \
           stty sum sync tac tail tee touch tr tsort tty uname unexpand \
           uniq unlink uptime users vdir wc who whoami yes \
           base32 base64 basename basenc b2sum cksum comm csplit \
           env fold pathchk pinky ptx sha224sum sha384sum shred \
           truncate tsort unexpand \
           grep sed awk find tar gzip xargs \
           bc bzip2 diff diff3 cmp; do
    install_binary "$bin" "$PREFIX/usr/bin"
done

# ── Symlinks for Homebrew-installed languages ───────────────────
for lang in python@3.13:python3 ruby lua node; do
    pkg="${lang%%:*}"
    bin="${lang##*:}"
    if [ -f "$PREFIX/usr/local/opt/$pkg/bin/$bin" ]; then
        ln -sf "$PREFIX/usr/local/opt/$pkg/bin/$bin" "$PREFIX/usr/bin/$bin"
    fi
done

# ── Config files ────────────────────────────────────────────────
cat > "$PREFIX/etc/shells" << 'EOF'
/bin/bash
/bin/sh
EOF

# ── Pass-through symlinks ───────────────────────────────────────
ln -sf /dev "$PREFIX/dev" 2>/dev/null || true
ln -sf /tmp "$PREFIX/tmp" 2>/dev/null || true

echo ""
echo "Rootfs setup complete:"
echo "  /bin/       — $(ls "$PREFIX/bin/" 2>/dev/null | wc -l) files"
echo "  /usr/bin/   — $(ls "$PREFIX/usr/bin/" 2>/dev/null | wc -l) files"
