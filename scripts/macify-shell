#!/bin/bash
# macify-shell — interactive shell for running macOS binaries on Linux
#
# Usage: macify-shell [options] [command [args...]]
#
# Like Wine's `wine cmd`, this provides an interactive shell that can
# run both macOS and Linux binaries transparently. macOS Mach-O binaries
# are automatically run through the macify translator; Linux binaries
# run natively.
#
# Without a command, starts an interactive REPL.
# With a command, runs it and exits.

# ── Setup ──────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
MACIFY_BIN="$PROJECT_DIR/build/macify"
SHIM_DIR="$PROJECT_DIR/build"

# ── Parse options ──────────────────────────────────────────────
VERBOSE=""
PREFIX="${MACIFY_PREFIX:-$HOME/.macify}"
while [[ "$1" == --* ]]; do
    case "$1" in
        --prefix) PREFIX="$2"; shift 2;;
        --verbose|-v) VERBOSE="1"; shift;;
        --help|-h)
            cat <<EOF
Usage: macify-shell [options] [command [args...]]

Interactive shell for running macOS binaries on Linux.

Options:
  --prefix <dir>   Set prefix directory (default: ~/.macify)
  -v, --verbose    Enable verbose macify loader output
  -h, --help       Show this help

Without a command, starts an interactive REPL.
With a command, runs it and exits.

In the shell:
  - Type any command to run it (macOS binaries auto-detected)
  - 'help' for built-in commands
  - 'exit' to quit
EOF
            exit 0
            ;;
        *) break;;
    esac
done

# ── Environment ────────────────────────────────────────────────
export LD_LIBRARY_PATH="$SHIM_DIR:${LD_LIBRARY_PATH:-}"
export MACIFY_PREFIX="$PREFIX"
[ -n "$VERBOSE" ] && export MACIFY_VERBOSE=1

# macify is quiet by default; only show output if explicitly requested
MACIFY_OPTS=""
[ -n "$VERBOSE" ] && MACIFY_OPTS="-v"

# ── Functions ──────────────────────────────────────────────────

# Check if a file is a macOS Mach-O binary
is_macho() {
    local file="$1"
    [ -f "$file" ] || return 1
    local magic
    magic=$(od -A n -t x1 -N 4 "$file" 2>/dev/null | tr -d ' \n')
    case "$magic" in
        cffaedfe*|feedfacf*|cafebabe*|bebafeca*) return 0;;
        *) return 1;;
    esac
}

# Find a macOS binary: full path, tests/real/<name>_macos, or prefix/bin/<name>
find_macos_bin() {
    local name="$1"
    if [[ "$name" == */* ]] && [ -f "$name" ]; then
        echo "$name"; return 0
    fi
    local found
    found=$(find "$PROJECT_DIR/tests/real" -maxdepth 1 \( -name "${name}_macos" -o -name "${name}_darwin" \) 2>/dev/null | head -1)
    if [ -n "$found" ]; then echo "$found"; return 0; fi
    if [ -f "$PREFIX/bin/$name" ]; then echo "$PREFIX/bin/$name"; return 0; fi
    return 1
}

# Run a macOS binary through macify (quiet by default)
run_macos() {
    "$MACIFY_BIN" $MACIFY_OPTS "$@"
}

# Show help
show_help() {
    cat <<EOF

macify-shell — macOS binary translator shell

This is a normal Linux shell with the macify environment set up.
macOS Mach-O binaries are automatically detected and run through the
macify translator.

Environment:
  MACIFY_PREFIX   $PREFIX
  LD_LIBRARY_PATH $SHIM_DIR

Built-in commands:
  help              Show this help
  exit              Exit the shell
  macify <bin>      Explicitly run a binary through macify
  macify-init       Initialize/update the prefix
  macify-version    Show macify version
  macify-prefix     Show the prefix path

Everything else runs as a normal shell command. If the command is
a macOS Mach-O binary (found in tests/real/ or prefix/bin/), it runs
through macify automatically.

Examples:
  ls /tmp           # runs macOS ls_macos if available, else Linux ls
  cat file.txt      # runs macOS cat_macos if available, else Linux cat
  echo \$PATH       # shows the current PATH
  macify ls_macos   # explicitly run through macify

EOF
}

# ── Initialize prefix if needed ────────────────────────────────
if [ ! -f "$PREFIX/.macify_prefix" ]; then
    "$SCRIPT_DIR/macify-init" --prefix "$PREFIX" >/dev/null 2>&1 || true
fi

# ── Non-interactive mode ───────────────────────────────────────
if [ $# -gt 0 ]; then
    cmd="$1"; shift
    case "$cmd" in
        help) show_help; exit 0;;
        macify) run_macos "$@"; exit $?;;
        macify-init) "$SCRIPT_DIR/macify-init" --prefix "$PREFIX"; exit $?;;
        macify-version) "$MACIFY_BIN" --help 2>&1 | head -1; exit 0;;
        macify-prefix) echo "$PREFIX"; exit 0;;
    esac
    # Try macOS binary first
    binpath=$(find_macos_bin "$cmd") || binpath=""
    if [ -n "$binpath" ]; then
        if is_macho "$binpath"; then run_macos "$binpath" "$@"; exit $?; fi
        "$binpath" "$@"; exit $?
    fi
    # Fall through to native command
    exec "$cmd" "$@"
fi

# ── Interactive mode ───────────────────────────────────────────

# Banner
echo ""
echo "  macify-shell v1.0 — macOS binary translator"
echo "  Prefix: $PREFIX"
echo "  Type 'help' for commands, 'exit' to quit"
echo ""

# Interactive loop
while true; do
    # Prompt
    printf 'macify:%s$ ' "$(pwd)"
    if ! IFS= read -r line; then
        echo ""
        break
    fi
    [ -z "$line" ] && continue

    # Parse
    set -- $line
    cmd="$1"
    [ $# -gt 0 ] && shift

    # Built-in commands that don't need variable expansion
    case "$cmd" in
        help) show_help; continue;;
        exit|quit) echo "Exiting macify-shell"; break;;
        macify) run_macos "$@"; continue;;
        macify-init) "$SCRIPT_DIR/macify-init" --prefix "$PREFIX"; continue;;
        macify-version) "$MACIFY_BIN" --help 2>&1 | head -1; continue;;
        macify-prefix) echo "$PREFIX"; continue;;
    esac

    # Try macOS binary — but only for simple commands (no pipes/redirects)
    if [[ "$line" != *'|'* && "$line" != *'>'* && "$line" != *'<'* ]]; then
        binpath=$(find_macos_bin "$cmd") || binpath=""
        if [ -n "$binpath" ] && is_macho "$binpath"; then
            # Expand variables in arguments
            eval "set -- $*"
            run_macos "$binpath" "$@"
            continue
        fi
    fi

    # Run as shell command (eval handles variable expansion, pipes, redirects)
    eval "$line"
done
