#!/bin/bash
# macify-shell — interactive macOS environment shell
#
# Like Wine's `wine cmd`, this provides a shell that runs inside the
# macify prefix (~/.macify/). The shell presents a macOS-like filesystem
# view: /usr/bin, /bin, /usr/local/bin are all within the prefix.
#
# Only the user's home directory is symlinked from the host.
# Host system paths are NOT visible.

# ── Setup ──────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
MACIFY_BIN="$PROJECT_DIR/build/macify"
SHIM_DIR="$PROJECT_DIR/build"
PREFIX="${MACIFY_PREFIX:-$HOME/.macify}"

# ── Parse options ──────────────────────────────────────────────
VERBOSE=""
while [[ "$1" == --* || "$1" == -[a-z] ]]; do
    case "$1" in
        --prefix) PREFIX="$2"; shift 2;;
        --verbose|-v) VERBOSE="-v"; shift;;
        --help|-h)
            cat <<'EOF'
Usage: macify-shell [options] [command [args...]]

Interactive shell running inside the macify prefix (~/.macify/).
macOS Mach-O binaries in /usr/bin, /bin, /usr/local/bin are run
through the macify translator automatically.

Options:
  --prefix <dir>   Set prefix directory (default: ~/.macify)
  -v, --verbose    Enable verbose macify loader output
  -h, --help       Show this help

Without a command, starts an interactive REPL.
With a command, runs it and exits.
EOF
            exit 0
            ;;
        *) break;;
    esac
done

# ── Ensure prefix exists ───────────────────────────────────────
if [ ! -f "$PREFIX/.macify_prefix" ]; then
    echo "macify-shell: initializing prefix at $PREFIX..."
    export LD_LIBRARY_PATH="$SHIM_DIR"
    export MACIFY_PREFIX="$PREFIX"
    "$MACIFY_BIN" "$PROJECT_DIR/tests/real/echo_macos" "init" >/dev/null 2>&1
fi

if [ ! -d "$PREFIX" ]; then
    echo "macify-shell: ERROR — prefix not found at $PREFIX"
    exit 1
fi

# ── Environment ────────────────────────────────────────────────
export LD_LIBRARY_PATH="$SHIM_DIR"
export MACIFY_PREFIX="$PREFIX"

# macOS-like PATH: all paths are within the prefix
# The macify translator translates these to real paths internally
export PATH="/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin"

# macOS-like HOME — stays as the real home (symlinked into prefix)
export HOME="$HOME"

# macOS-like shell
export SHELL="/bin/bash"

# ── Functions ──────────────────────────────────────────────────

# Check if a file is a macOS Mach-O binary
is_macho() {
    [ -f "$1" ] || return 1
    local magic
    magic=$(od -A n -t x1 -N 4 "$1" 2>/dev/null | tr -d ' \n')
    case "$magic" in
        cffaedfe*|feedfacf*|cafebabe*|bebafeca*) return 0;;
        *) return 1;;
    esac
}

# Find a binary in the prefix's PATH
# Returns the real path on disk (within the prefix)
find_in_prefix() {
    local name="$1"
    # Search prefix bin directories
    for dir in "$PREFIX/usr/bin" "$PREFIX/bin" "$PREFIX/usr/local/bin" "$PREFIX/usr/sbin" "$PREFIX/sbin"; do
        if [ -f "$dir/$name" ]; then
            echo "$dir/$name"
            return 0
        fi
    done
    return 1
}

# Run a macOS binary through macify
run_macos() {
    "$MACIFY_BIN" $VERBOSE "$@"
}

# Show help
show_help() {
    cat <<EOF

macify-shell — macOS environment

This shell runs inside the macify prefix: $PREFIX

The filesystem looks like macOS:
  /usr/bin/     — macOS binaries (run through macify)
  /bin/         — essential macOS binaries
  /usr/local/   — locally installed macOS binaries
  /etc/         — macOS-style config files
  /tmp/         — temporary files (shared with host)
  ~/Library/    — macOS Library directory

Only your home directory is shared with the host system.

Commands:
  help              Show this help
  exit              Exit the shell
  macify <bin>      Explicitly run a binary through macify
  macify-init       Re-initialize the prefix
  macify-version    Show macify version
  install <bin>     Install a macOS binary into the prefix

Any other command searches /usr/bin, /bin, /usr/local/bin in the prefix.
If found and it's a Mach-O binary, it runs through macify.
If not found, it runs as a native Linux command (for builtins like cd, echo).

EOF
}

# Install a macOS binary into the prefix
do_install() {
    local src="$1"
    local name="${2:-$(basename "$src")}"
    if [ ! -f "$src" ]; then
        echo "install: $src not found"
        return 1
    fi
    if ! is_macho "$src"; then
        echo "install: $src is not a Mach-O binary"
        return 1
    fi
    cp "$src" "$PREFIX/usr/bin/$name"
    chmod +x "$PREFIX/usr/bin/$name"
    echo "installed: $name → /usr/bin/$name"
}

# ── Non-interactive mode ───────────────────────────────────────
if [ $# -gt 0 ]; then
    cmd="$1"; shift
    case "$cmd" in
        help) show_help; exit 0;;
        macify) run_macos "$@"; exit $?;;
        macify-init)
            export MACIFY_PREFIX="$PREFIX"
            "$MACIFY_BIN" "$PROJECT_DIR/tests/real/echo_macos" "init" >/dev/null 2>&1
            echo "Prefix initialized at $PREFIX"
            exit 0;;
        macify-version) echo "macify 1.0"; exit 0;;
        macify-prefix) echo "$PREFIX"; exit 0;;
        install) do_install "$@"; exit $?;;
    esac
    # Search in prefix
    binpath=$(find_in_prefix "$cmd") || binpath=""
    if [ -n "$binpath" ]; then
        run_macos "$binpath" "$@"
        exit $?
    fi
    # Try as shell builtin/command
    eval "$cmd $*"
    exit $?
fi

# ── Interactive mode ───────────────────────────────────────────

echo ""
echo "  macify-shell v1.0"
echo "  Prefix: $PREFIX"
echo "  Type 'help' for commands, 'exit' to quit"
echo ""

# Start in the user's home directory
cd "$HOME" 2>/dev/null

while true; do
    printf 'macify:%s$ ' "$(pwd)"
    if ! IFS= read -r line; then
        echo ""
        break
    fi
    [ -z "$line" ] && continue

    # Parse
    set -- $line
    cmd="$1"
    [ $# -gt 0 ] && shift

    # Built-in commands (no variable expansion needed)
    case "$cmd" in
        help) show_help; continue;;
        exit|quit) break;;
        macify) run_macos "$@"; continue;;
        macify-init)
            export MACIFY_PREFIX="$PREFIX"
            "$MACIFY_BIN" "$PROJECT_DIR/tests/real/echo_macos" "init" >/dev/null 2>&1
            echo "Prefix re-initialized"; continue;;
        macify-version) echo "macify 1.0"; continue;;
        macify-prefix) echo "$PREFIX"; continue;;
        install) do_install "$@"; continue;;
        cd) builtin cd "$@" 2>/dev/null; continue;;
        pwd) pwd; continue;;
        export) builtin export "$@"; continue;;
    esac

    # Search for macOS binary in prefix
    binpath=$(find_in_prefix "$cmd") || binpath=""
    if [ -n "$binpath" ] && is_macho "$binpath"; then
        # Expand variables in args
        eval "set -- $*"
        run_macos "$binpath" "$@"
        continue
    fi

    # Run as shell command (handles variables, pipes, redirects)
    eval "$line"
done

echo ""
echo "macify-shell exited"
