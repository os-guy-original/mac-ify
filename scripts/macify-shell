#!/bin/bash
# macify-shell — run a macOS bash shell inside the macify prefix
#
# Like Wine's `wine cmd`, this runs a real macOS binary (bash) inside
# the macify prefix. The macOS bash sees / as the prefix root.
#
# Usage:
#   macify-shell                  # interactive shell
#   macify-shell 'echo hello'     # run command
#   macify-shell -v 'echo hello'  # verbose

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
MACIFY_BIN="$PROJECT_DIR/build/macify"
SHIM_DIR="$PROJECT_DIR/build"
PREFIX="${MACIFY_PREFIX:-$HOME/.macify}"

# ── Parse options ───────────────────────────────────────────────
VERBOSE=""
while [[ "$1" == --* || "$1" == -[a-z] ]]; do
    case "$1" in
        --prefix) PREFIX="$2"; shift 2;;
        -v|--verbose) VERBOSE="-v"; shift;;
        -h|--help)
            cat <<'EOF'
Usage: macify-shell [options] [command [args...]]

Runs a real macOS bash binary inside the macify prefix.
Without a command: starts interactive macOS bash.
With a command:    runs `bash -c "<command>"` (macOS bash).

Options:
  --prefix <dir>   Set prefix directory (default: ~/.macify)
  -v, --verbose    Enable verbose macify loader output
  -h, --help       Show this help
EOF
            exit 0;;
        *) break;;
    esac
done

export MACIFY_PREFIX="$PREFIX"
export LD_LIBRARY_PATH="$SHIM_DIR"

# ── Ensure prefix and rootfs exist ──────────────────────────────
if [ ! -f "$PREFIX/.macify_prefix" ] || [ ! -f "$PREFIX/bin/bash" ] || [ ! -d "$PREFIX/usr/local/opt/readline" ]; then
    echo "macify-shell: initializing prefix at $PREFIX..." >&2
    bash "$SCRIPT_DIR/macify-setup-rootfs" >&2
fi

if [ ! -f "$PREFIX/bin/bash" ]; then
    echo "macify-shell: ERROR — macOS bash not found at $PREFIX/bin/bash" >&2
    exit 1
fi

# ── Run macOS bash ──────────────────────────────────────────────
if [ $# -gt 0 ]; then
    exec "$MACIFY_BIN" $VERBOSE "$PREFIX/bin/bash" -c "$*"
else
    exec "$MACIFY_BIN" $VERBOSE "$PREFIX/bin/bash" --login -i
fi
